{
  "manifest_version": 3,
  "name": "KB Clipper",
  "version": "1.0.0",
  "description": "Clip web pages directly into your personal or work knowledge base",

  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "nativeMessaging",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "KB Clipper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  }
}
